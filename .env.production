# Production environment variables
# Vite loads this automatically when building in production mode (npm run build)
# NOTE: API keys here are embedded in the client bundle (see OpenRouterService.ts warning)

# Recognition API URL (for handwriting recognition)
INK_RECOGNITION_API_URL=https://strokes.hack.ink.ai/

# OpenRouter API key (for LLM inference — client-side, use a scoped low-privilege key)
INK_OPENROUTER_API_KEY=

# Upload API URL (for Share on Telegram — ZIP file hosting)
INK_UPLOAD_API_URL=https://ink-upload-server-859414203684.us-central1.run.app
